rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidContact(data) {
      return data.keys().hasAll(['name', 'type', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.type in ['wholesaler', 'customer'] &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'wholesalerId', 'wholesalerName', 'cost', 'purchaseDate', 'status', 'createdAt']) &&
             data.keys().size() >= 8 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.wholesalerId is string &&
             data.wholesalerName is string &&
             data.cost is number && data.cost >= 0 &&
             data.purchaseDate is string &&
             data.status in ['In Stock', 'Sold'] &&
             data.createdAt == request.time;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['productId', 'productName', 'customerId', 'customerName', 'retailPrice', 'costAtSale', 'saleDate', 'createdAt']) &&
             data.keys().size() >= 8 &&
             data.productId is string &&
             data.customerId is string &&
             data.retailPrice is number && data.retailPrice >= 0 &&
             data.costAtSale is number && data.costAtSale >= 0 &&
             data.saleDate is string &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /contacts/{contactId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidContact(incoming());
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone'])
      );
      allow delete: if isSignedIn();
    }

    match /inventory/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && (
        // Action: Mark as Sold
        (incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'Sold') ||
        // Action: General Edit
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'cost']))
      );
      allow delete: if isSignedIn();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    isValidSale(incoming()) && 
                    existsAfter(/databases/$(database)/documents/inventory/$(incoming().productId));
      allow delete: if isSignedIn();
    }
  }
}
