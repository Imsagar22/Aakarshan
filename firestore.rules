rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---

    function isValidContact(data) {
      return data.userId == request.auth.uid 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.type in ['wholesaler', 'customer'];
    }

    function isValidProduct(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.category is string
        && data.cost is number && data.cost >= 0
        && data.quantity is number && data.quantity >= 0
        && data.status in ['In Stock', 'Sold'];
    }

    function isValidSale(data) {
      return data.userId == request.auth.uid
        && data.productId is string
        && data.customerId is string
        && data.retailPrice is number && data.retailPrice >= 0
        && data.costAtSale is number && data.costAtSale >= 0
        && data.quantity is number && data.quantity > 0;
    }

    function isValidInventoryLog(data) {
      return data.userId == request.auth.uid
        && data.productId is string
        && data.type in ['sale', 'restock', 'adjustment']
        && data.quantityChange is number
        && data.date is string;
    }

    // --- Rules ---

    match /contacts/{contactId} {
      allow create: if isSignedIn() && isValidContact(incoming()) && isValidId(contactId);
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidContact(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /inventory/{productId} {
      allow create: if isSignedIn() && isValidProduct(incoming()) && isValidId(productId);
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidProduct(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /sales/{saleId} {
      allow create: if isSignedIn() && isValidSale(incoming()) && isValidId(saleId);
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidSale(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /inventory_logs/{logId} {
      allow create: if isSignedIn() && isValidInventoryLog(incoming()) && isValidId(logId);
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidInventoryLog(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /metrics/{metricId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

  }
}
