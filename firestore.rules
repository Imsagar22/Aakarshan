rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == 'sagarmailstop@gmail.com';
    }

    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidContact(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'createdAt']) &&
             data.keys().size() >= 4 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.type in ['wholesaler', 'customer'] &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['userId', 'name', 'category', 'wholesalerId', 'wholesalerName', 'cost', 'status', 'purchaseDate', 'createdAt']) &&
             data.keys().size() >= 9 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             isValidId(data.wholesalerId) &&
             data.wholesalerName is string &&
             data.cost is number && data.cost >= 0 &&
             data.status in ['In Stock', 'Sold'] &&
             data.purchaseDate is string &&
             data.createdAt == request.time;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['userId', 'productId', 'productName', 'customerId', 'customerName', 'retailPrice', 'costAtSale', 'saleDate', 'createdAt']) &&
             data.keys().size() >= 9 &&
             data.userId == request.auth.uid &&
             isValidId(data.productId) &&
             isValidId(data.customerId) &&
             data.retailPrice is number && data.retailPrice >= 0 &&
             data.costAtSale is number && data.costAtSale >= 0 &&
             data.saleDate is string &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /contacts/{contactId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidContact(incoming());
      allow update: if isVerified() && isOwner(existing()) && isValidContact(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }

    match /inventory/{productId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidProduct(incoming());
      allow update: if isVerified() && isOwner(existing()) && isValidProduct(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }

    match /sales/{saleId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidSale(incoming());
      allow update: if isVerified() && isOwner(existing()) && isValidSale(incoming());
      allow delete: if isVerified() && isOwner(existing());
    }

    match /users/{userId} {
      allow read: if isVerified() && (request.auth.uid == userId || isAdmin());
      allow write: if isVerified() && request.auth.uid == userId;
    }

    match /metrics/{metricId} {
      allow read: if isAdmin();
      allow write: if false; // System only (handled by cloud function or manual admin)
    }
  }
}
