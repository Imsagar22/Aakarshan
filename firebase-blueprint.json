{
  "entities": {
    "contact": {
      "title": "Contact",
      "description": "A wholesaler or customer contact.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["wholesaler", "customer"] },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type"]
    },
    "product": {
      "title": "Product",
      "description": "An item in the jewelry inventory.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "wholesalerId": { "type": "string" },
        "wholesalerName": { "type": "string" },
        "cost": { "type": "number" },
        "quantity": { "type": "number" },
        "purchaseDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["In Stock", "Sold"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "category", "wholesalerId", "cost", "quantity", "purchaseDate", "status"]
    },
    "sale": {
      "title": "Sale",
      "description": "A completed sale transaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "quantity": { "type": "number" },
        "retailPrice": { "type": "number" },
        "costAtSale": { "type": "number" },
        "saleDate": { "type": "string", "format": "date" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Credit"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "customerId", "quantity", "retailPrice", "costAtSale", "saleDate", "paymentStatus"]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "Basic information about an app user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["email"]
    },
    "appMetrics": {
      "title": "App Metrics",
      "description": "Global application usage statistics.",
      "type": "object",
      "properties": {
        "totalUsers": { "type": "number" },
        "totalSales": { "type": "number" },
        "totalInventoryValue": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "contacts": { "schema": "contact", "description": "Directory of wholesalers and customers." },
    "inventory": { "schema": "product", "description": "Active and sold product inventory." },
    "sales": { "schema": "sale", "description": "Sales history records." },
    "users": { "schema": "userProfile", "description": "User profile records." },
    "metrics": { "schema": "appMetrics", "description": "Global dashboard metrics." }
  }
}
